{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "files-route": {
        "ClusterId": "storage-cluster",
        "Match": {
          "Path": "/api/files/{**catch-all}"
        }
      },
      "s3-route": {
        "ClusterId": "storage-cluster",
        "Match": {
          "Path": "/s3/{**catch-all}"
        }
      },
      "contracts-route": {
        "ClusterId": "contracts-cluster",
        "Match": {
          "Path": "/api/contracts/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://localhost:5291/"
          }
        }
      },
      "storage-cluster": {
        "Destinations": {
          "storage": {
            "Address": "http://localhost:5289/"
          }
        }
      },
      "contracts-cluster": {
        "Destinations": {
          "contracts": {
            "Address": "http://localhost:5290/"
          }
        }
      }
    }
  }
}

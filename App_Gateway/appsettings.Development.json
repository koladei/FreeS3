{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "ui-route": {
        "ClusterId": "ui-cluster",
        "Match": {
          "Path": "/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "ui-cluster": {
        "Destinations": {
          "ui": {
            "Address": "http://localhost:5173/"
          }
        }
      }
    }
  }
}
